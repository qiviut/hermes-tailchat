{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/hermes-tailchat/swyx-skill-candidate.schema.json",
  "title": "Swyx skill candidate observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "source_refs",
    "claim",
    "evidence",
    "skill_trigger",
    "workflow_steps",
    "tooling",
    "risk_notes",
    "confidence",
    "proposed_skill_name"
  ],
  "properties": {
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "claim": {"type": "string", "minLength": 1, "maxLength": 500},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_ref", "quote"],
        "properties": {
          "source_ref": {"type": "string", "minLength": 1},
          "quote": {"type": "string", "minLength": 1, "maxLength": 1000},
          "timestamp": {"type": "string"},
          "url": {"type": "string"}
        }
      }
    },
    "skill_trigger": {"type": "string", "minLength": 1, "maxLength": 500},
    "workflow_steps": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "maxLength": 500}
    },
    "tooling": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 120}
    },
    "risk_notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 300}
    },
    "confidence": {"enum": ["low", "medium", "high"]},
    "proposed_skill_name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}[a-z0-9]$"
    }
  }
}
