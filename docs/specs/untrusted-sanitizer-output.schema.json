{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hermes-tailchat.local/specs/untrusted-sanitizer-output.schema.json",
  "title": "Untrusted Sanitizer Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "content_kind",
    "intent",
    "risk_flags",
    "safe_extract",
    "confidence",
    "needs_escalation",
    "escalation_reason"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },
    "content_kind": {
      "type": "string",
      "enum": [
        "chat",
        "code",
        "config",
        "email",
        "git",
        "log",
        "news",
        "social",
        "unknown",
        "web"
      ]
    },
    "intent": {
      "type": "string",
      "enum": [
        "analysis",
        "attack_like",
        "informational",
        "instructional",
        "request",
        "status",
        "unknown"
      ]
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 80
      },
      "maxItems": 16
    },
    "safe_extract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actionable_facts",
        "quoted_snippets"
      ],
      "properties": {
        "actionable_facts": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 240
          },
          "maxItems": 12
        },
        "quoted_snippets": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 240
          },
          "maxItems": 8
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "needs_escalation": {
      "type": "boolean"
    },
    "escalation_reason": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 240
    }
  }
}
