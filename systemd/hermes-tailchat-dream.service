[Unit]
Description=Collect deterministic Hermes dreaming telemetry
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/.openclaw/workspace/hermes-tailchat
Environment=HERMES_BIN=%h/.local/bin/hermes
ExecStart=/usr/bin/env python3 %h/.openclaw/workspace/hermes-tailchat/scripts/hermes_dream.py
