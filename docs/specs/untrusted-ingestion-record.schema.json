{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/hermes-tailchat/untrusted-ingestion-record.schema.json",
  "title": "Untrusted ingestion normalized record",
  "type": "object",
  "required": [
    "artifact_id",
    "source_type",
    "source_ref",
    "pipeline",
    "normalized_text",
    "structured_fields",
    "domains",
    "commands",
    "secret_like_findings",
    "deterministic_flags",
    "risk_hints",
    "deterministic_summary",
    "truncation",
    "next_stage_hint"
  ],
  "properties": {
    "artifact_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "source_type": {"type": "string"},
    "source_ref": {"type": "string"},
    "fetched_at": {"type": ["string", "null"]},
    "pipeline": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name": {"type": "string"},
        "path": {"type": "string"},
        "max_chars": {"type": ["integer", "null"]},
        "max_lines": {"type": ["integer", "null"]}
      },
      "additionalProperties": true
    },
    "normalized_text": {"type": "string"},
    "structured_fields": {"type": "object"},
    "domains": {"type": "array", "items": {"type": "string"}},
    "commands": {"type": "array", "items": {"type": "string"}},
    "secret_like_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pattern", "sample"],
        "properties": {
          "pattern": {"type": "string"},
          "sample": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "deterministic_flags": {"type": "array", "items": {"type": "string"}},
    "risk_hints": {"type": "array", "items": {"type": "string"}},
    "deterministic_summary": {"type": "string"},
    "truncation": {
      "type": "object",
      "required": ["was_truncated", "line_truncated", "char_truncated", "original_lines", "original_chars", "normalized_chars"],
      "properties": {
        "was_truncated": {"type": "boolean"},
        "line_truncated": {"type": "boolean"},
        "char_truncated": {"type": "boolean"},
        "original_lines": {"type": "integer"},
        "original_chars": {"type": "integer"},
        "normalized_chars": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "next_stage_hint": {
      "type": "object",
      "required": ["default_consumer", "escalate_if_any"],
      "properties": {
        "default_consumer": {"type": "string"},
        "escalate_if_any": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}